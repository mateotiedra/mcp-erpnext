{
  "name": "@casys/mcp-erpnext",
  "version": "2.3.0",
  "nodeModulesDir": "auto",
  "tasks": {
    "serve": "deno run --allow-all server.ts --http --port=3012",
    "compile": "deno compile -A --output mcp-erpnext server.ts",
    "test": "deno test --allow-all src/",
    "ui:build": "cd src/ui && node build-all.mjs",
    "inspect": "deno run --allow-all server.ts --inspect",
    "check": "deno check mod.ts server.ts",
    "pre-commit": "deno fmt --check && deno lint && deno task check",
    "release:check": "bash scripts/release-check.sh",
    "hooks:install": "bash scripts/install-hooks.sh"
  },
  "exports": {
    ".": "./mod.ts",
    "./server": "./server.ts"
  },
  "publish": {
    "include": [
      "mod.ts",
      "server.ts",
      "src/**/*.ts",
      "src/ui/dist/",
      "README.md",
      "LICENSE"
    ],
    "exclude": [
      "**/*_test.ts",
      "**/*.test.ts",
      "**/*.bench.ts"
    ]
  },
  "lint": {
    "exclude": [
      "src/ui/**/*.tsx",
      "src/ui/**/*.mjs",
      "src/ui/node_modules/"
    ],
    "rules": {
      "exclude": [
        "require-await"
      ]
    }
  },
  "fmt": {
    "exclude": [
      "src/ui/node_modules/"
    ]
  },
  "test": {
    "exclude": [
      "src/ui/node_modules/",
      "src/ui/dist/"
    ]
  },
  "imports": {
    "@casys/mcp-server": "jsr:@casys/mcp-server@^0.17",
    "hono": "npm:hono@^4",
    "hono/cors": "npm:hono@^4/cors",
    "jose": "npm:jose@^6.0.0",
    "@opentelemetry/api": "npm:@opentelemetry/api@^1.9.0",
    "@std/yaml": "jsr:@std/yaml@^1",
    "@std/assert": "jsr:@std/assert@^1"
  }
}
